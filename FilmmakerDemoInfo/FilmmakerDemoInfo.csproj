<Project Sdk="Microsoft.NET.Sdk">

  <!--
    FilmmakerDemoInfo: a tiny console tool that parses a CS2 .dem with demofile-net
    and prints a JSON summary (map, duration, scoreboard with player NAMES + K/A/D/
    score, and best-effort per-round kills/deaths/MVP) to stdout.

    AfxHookSource2's filmmaker demo browser shells out to this (in the background,
    cached next to each demo) to populate the Panorama UI. Names come from the demo
    entities here because the .dem.info matchmaking sidecar has account ids only.
  -->

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net9.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <AssemblyName>FilmmakerDemoInfo</AssemblyName>
    <RootNamespace>FilmmakerDemoInfo</RootNamespace>
    <InvariantGlobalization>true</InvariantGlobalization>
    <!-- demofile-net ships unsigned and its generated schema is not nullable-annotated -->
    <SignAssembly>false</SignAssembly>
    <NoWarn>$(NoWarn);CS8632;CS8002</NoWarn>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="DemoFile.Game.Cs" Version="0.44.1" />
  </ItemGroup>

</Project>
